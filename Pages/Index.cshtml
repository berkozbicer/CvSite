@page
@model IndexModel
@{
    ViewData["Title"] = "Anasayfa";
}

<!-- Hero -->
<section class="hero">
    <div class="hero-inner">
        <p class="hero-role">Software Developer</p>
        <h1 class="hero-name">Mustafa Berk<br><span>ÖZBİÇER</span></h1>
        <p class="hero-sub">C# · .NET · ASP.NET Core</p>
        <a href="#contact" class="btn-primary">İletişime Geç</a>
    </div>
    <div class="hero-deco" aria-hidden="true"></div>
</section>

<!-- Hakkımda -->
<section id="about" class="section">
    <div class="section-inner">
        <div class="section-label">01 — Hakkımda</div>
        <h2 class="section-title">Yazılım geliştirmeye tutkuyla bağlı bir geliştirici</h2>
        <p class="about-text">
            Anadolu Üniversitesi Bilgisayar Programlama önlisans derecesiyle mezun oldum (2025).
            Güvenilir ve verimli uygulamalar geliştirmeye büyük ilgi duyan, detaylara önem veren ve motive bir
            yazılım geliştiricisiyim. Sürekli öğrenmeye, kodlama uygulamalarını geliştirmeye ve dinamik
            ortamlarda yenilikçi projelere katkıda bulunmaya tutkuluyum.
        </p>
    </div>
</section>

<!-- Yetenekler -->
<section id="skills" class="section section-dark">
    <div class="section-inner">
        <div class="section-label">02 — Yetenekler</div>
        <h2 class="section-title">Teknoloji Yığını</h2>
        <div class="skills-grid">
            <div class="skill-card"><i class="fa-brands fa-microsoft"></i><span>C#</span></div>
            <div class="skill-card"><i class="fa-solid fa-layer-group"></i><span>.NET</span></div>
            <div class="skill-card"><i class="fa-solid fa-server"></i><span>ASP.NET Core</span></div>
            <div class="skill-card"><i class="fa-solid fa-database"></i><span>Entity Framework Core</span></div>
            <div class="skill-card"><i class="fa-solid fa-table"></i><span>SQL</span></div>
            <div class="skill-card"><i class="fa-brands fa-git-alt"></i><span>Git</span></div>
        </div>
    </div>
</section>

<!-- Projeler -->
<section id="projects" class="section">
    <div class="section-inner">
        <div class="section-label">03 — Projeler</div>
        <h2 class="section-title">Öne Çıkan Çalışmalar</h2>
        <div class="projects-grid">
            @foreach (var project in Model.Projects)
            {
                <div class="project-card">
                    <div class="project-card-top">
                        <i class="fa-solid fa-code project-icon"></i>
                        @if (!string.IsNullOrEmpty(project.GithubUrl))
                        {
                            <a href="@project.GithubUrl" target="_blank" class="project-github" title="GitHub'da Gör">
                                <i class="fa-brands fa-github"></i>
                            </a>
                        }
                    </div>
                    <h3 class="project-title">@project.Title</h3>
                    <p class="project-desc">@project.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- İletişim -->
<section id="contact" class="section section-dark">
    <div class="section-inner contact-inner">
        <div class="section-label">04 — İletişim</div>
        <h2 class="section-title">Birlikte Çalışalım</h2>
        <div class="contact-links">
            <a href="mailto:mustafaozbicer@icloud.com" class="contact-item">
                <i class="fa-solid fa-envelope"></i>
                <span>mustafaozbicer@icloud.com</span>
            </a>
            <a href="tel:+905316276401" class="contact-item">
                <i class="fa-solid fa-phone"></i>
                <span>+90 531 627 6401</span>
            </a>
            <a href="https://github.com/berkozbicer" target="_blank" class="contact-item">
                <i class="fa-brands fa-github"></i>
                <span>github.com/berkozbicer</span>
            </a>
        </div>
    </div>
</section>
